# --- Cal.com ---
# Get from cal.com > Settings > Developer > API Keys
CALCOM_API_KEY=cal_live_xxxxxxxxxxxx
# The Cal.com "event type" ID for the appointment slot you want to book (e.g. "New Patient Consult")
CALCOM_EVENT_TYPE_ID=123456
CALCOM_USERNAME=your-calcom-username

# --- Supabase ---
# Get from supabase.com project > Settings > API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxx

# --- Retell ---
# Optional: used to verify incoming webhook signatures (recommended for production)
RETELL_API_KEY=key_xxxxxxxxxxxx

# --- Server ---
PORT=3000
